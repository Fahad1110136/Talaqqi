# Environment variables for Talaqqi Backend
# Copy this to .env and fill in your values

# Application
DEBUG=True
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./talaqqi.db

# ML Model
MODEL_PATH=./models/tajweed_classifier.h5
CONFIDENCE_THRESHOLD=0.75

# Audio Processing
AUDIO_SAMPLE_RATE=16000
MFCC_N_COEFFICIENTS=40

# API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
